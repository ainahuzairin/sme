<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SM Explorer</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/sme.styles.css" asp-append-version="true" />

    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32.png" />

    <style>
            /* White circular plate behind the logo so it reads cleanly on dark backgrounds */
            .sm-logo-badge {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background-color: #ffffff;
                border-radius: 50%;
                line-height: 0;
            }

            .sm-navbar__brand .sm-logo-badge {
                width: 44px;
                height: 44px;
                padding: 4px;
            }

            .sm-footer__logo .sm-logo-badge {
                width: 36px;
                height: 36px;
                padding: 3px;
            }

            .sm-logo-badge img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }

            .sm-navbar__brand {
                display: inline-flex;
                align-items: center;
                gap: 10px;
            }

            .sm-navbar__brand-text {
                font-family: 'Inter', 'Segoe UI', sans-serif;
                font-weight: 600;
                font-size: 1rem;
                color: #1c1f24;
                letter-spacing: 0.08em;
                text-transform: uppercase;
            }

            /* ===================== RESPONSIVE NAV ===================== *
                         * site.css / sme.styles.css define the base nav look. These   *
                         * rules make sure the hamburger + dropdown behave correctly   *
                         * on small screens even if those stylesheets don't already    *
                         * cover it — safe to remove if duplicated there.              */
            .sm-navbar__inner {
                display: flex;
                align-items: center;
                justify-content: space-between;
                flex-wrap: wrap;
            }

            .sm-navbar__toggle {
                display: none;
                flex-direction: column;
                justify-content: center;
                gap: 5px;
                width: 34px;
                height: 34px;
                background: transparent;
                border: none;
                cursor: pointer;
                padding: 0;
            }

                .sm-navbar__toggle span {
                    display: block;
                    width: 100%;
                    height: 2px;
                    background: #1c1f24;
                    border-radius: 2px;
                }

            .sm-navbar__dropdown {
                position: relative;
            }

            /* !important throughout this block: site.css / sme.styles.css likely
                           already style .sm-dropdown__panel for a desktop hover dropdown
                           (opacity/visibility/max-height tricks), which can silently block
                           our JS-driven open state on mobile. These overrides guarantee the
                           panel actually shows regardless of what those stylesheets do. */
            .sm-dropdown__panel {
                display: none !important;
                visibility: hidden !important;
                opacity: 0 !important;
                max-height: 0 !important;
                overflow: hidden !important;
                pointer-events: none !important;
            }

            .sm-navbar__dropdown.sm-open .sm-dropdown__panel {
                display: block !important;
                visibility: visible !important;
                opacity: 1 !important;
                max-height: 1000px !important;
                overflow: visible !important;
                pointer-events: auto !important;
            }

            .sm-dropdown__panel {
                list-style: none;
                margin: 0.5rem 0 0;
                padding: 0;
            }

                .sm-dropdown__panel li {
                    padding: 0.45rem 0;
                }

                .sm-dropdown__panel a {
                    color: #1c1f24 !important;
                    text-decoration: none;
                    font-size: 0.95rem;
                }

                    .sm-dropdown__panel a:hover {
                        color: #c81e2c !important;
                    }

            @@media (max-width: 900px) {
                .sm-navbar__toggle {
                    display: flex;
                }

                .sm-navbar__menu {
                    display: none;
                    width: 100%;
                    order: 3;
                }

                    .sm-navbar__menu.sm-open {
                        display: block;
                    }

                .sm-navbar__links {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 0;
                    width: 100%;
                }

                    .sm-navbar__links > li {
                        width: 100%;
                    }

                .sm-dropdown__panel {
                    position: static !important;
                    padding-left: 1rem;
                }
            }
    </style>
</head>
<body>
    <header>
        <nav class="sm-navbar" id="smNavbar">
            <div class="sm-navbar__inner">
                <a class="sm-navbar__brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="sm-logo-badge">
                        <img src="~/images/logo.png" alt="SM Explorer logo" />
                    </span>
                    <span class="sm-navbar__brand-text">SM Explorer</span>
                </a>

                <button class="sm-navbar__toggle" id="smNavToggle" type="button" aria-controls="smNavMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <span></span><span></span><span></span>
                </button>

                <div class="sm-navbar__menu" id="smNavMenu">
                    <ul class="sm-navbar__links">
                        <li><a class="sm-navlink is-active" asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="sm-navbar__dropdown" id="smAboutDropdown">
                            <button class="sm-navlink sm-navlink--dropdown" type="button" aria-expanded="false">
                                About <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
                            </button>
                            <ul class="sm-dropdown__panel">
                                <li><a asp-area="" asp-controller="Home" asp-action="CompanyProfile">Company Profile</a></li>
                                <li><a asp-area="" asp-controller="Home" asp-action="Awards">Awards</a></li>
                                <li><a asp-area="" asp-controller="Home" asp-action="TrackRecord">Track Record</a></li>
                            </ul>
                        </li>
                        <li><a class="sm-navlink" asp-area="" asp-controller="Home" asp-action="Policy">Policy</a></li>
                        <li><a class="sm-navlink" asp-area="" asp-controller="Home" asp-action="Clients">Clients</a></li>
                        <li><a class="sm-navlink" asp-area="" asp-controller="Home" asp-action="Career">Career</a></li>
                        <li><a class="sm-navlink" asp-area="" asp-controller="Home" asp-action="Contact">Contact Us</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="sm-footer">
        <div class="sm-footer__inner container">
            <div class="sm-footer__col sm-footer__col--brand">
                <div class="sm-footer__logo">
                    <span class="sm-logo-badge">
                        <img src="~/images/logo.png" alt="SM Explorer logo" />
                    </span>
                    <span>SM EXPLORER</span>
                </div>
                <p>Trading Beyond Borders.<br />Creating Lasting Value.</p>
            </div>

            <div class="sm-footer__col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-area="" asp-controller="Home" asp-action="CompanyProfile">About</a></li>
                    <li class="sm-footer__sub"><a asp-area="" asp-controller="Home" asp-action="CompanyProfile">- Company Profile</a></li>
                    <li class="sm-footer__sub"><a asp-area="" asp-controller="Home" asp-action="Awards">- Awards</a></li>
                    <li class="sm-footer__sub"><a asp-area="" asp-controller="Home" asp-action="TrackRecord">- Track Record</a></li>
                </ul>
            </div>

            <div class="sm-footer__col">
                <h4>&nbsp;</h4>
                <ul>
                    <li><a asp-area="" asp-controller="Home" asp-action="Policy">Policy</a></li>
                    <li><a asp-area="" asp-controller="Home" asp-action="Clients">Clients</a></li>
                    <li><a asp-area="" asp-controller="Home" asp-action="Career">Career</a></li>
                    <li><a asp-area="" asp-controller="Home" asp-action="Contact">Contact</a></li>
                </ul>
            </div>

            <div class="sm-footer__col">
                <h4>Contact Us</h4>
                <ul class="sm-footer__contact">
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 22s7-7.58 7-12.5A7 7 0 0 0 5 9.5C5 14.42 12 22 12 22Z" stroke="currentColor" stroke-width="1.6" /><circle cx="12" cy="9.5" r="2.4" stroke="currentColor" stroke-width="1.6" /></svg>
                        Shah Alam, Selangor, Malaysia
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M3 6.5 12 13l9-6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6" /></svg>
                        trading@smexplorer.com.my
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L14 13l5 2v4a2 2 0 0 1-2 2C9.5 21 3 14.5 3 6a2 2 0 0 1 1-2Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" /></svg>
                        +60 5545 2540
                    </li>
                </ul>
                <div class="sm-footer__social">
                    @*    <a href="#" aria-label="LinkedIn">in</a>
                    <a href="#" aria-label="Facebook">f</a>
                    <a href="#" aria-label="Website"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" /><path d="M3 12h18M12 3c2.5 2.5 4 5.7 4 9s-1.5 6.5-4 9c-2.5-2.5-4-5.7-4-9s1.5-6.5 4-9Z" stroke="currentColor" stroke-width="1.4" /></svg></a>
              *@
                </div>
            </div>
        </div>
        <div class="sm-footer__bottom">
            &copy; @DateTime.Now.Year SM Explorer. All Rights Reserved.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
            (function() {
                // Hamburger toggle for mobile nav
                var toggle = document.getElementById('smNavToggle');
                var menu = document.getElementById('smNavMenu');
                if (toggle && menu) {
                    toggle.addEventListener('click', function() {
                        var isOpen = menu.classList.toggle('sm-open');
                        toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                    });
                }

                // "About" dropdown toggle (tap to open on mobile, since there's no hover)
                var aboutDropdown = document.getElementById('smAboutDropdown');
                if (aboutDropdown) {
                    var aboutBtn = aboutDropdown.querySelector('.sm-navlink--dropdown');
                    if (aboutBtn) {
                        aboutBtn.addEventListener('click', function() {
                            var isOpen = aboutDropdown.classList.toggle('sm-open');
                            aboutBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                        });
                    }
                }
            })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
