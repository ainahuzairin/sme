@{
    ViewData["Title"] = "Home";
}

<style>
    /* ==========================================================================
               Home page — hero, trading focus, about, stats, clients, CTA
               (page-scoped; shared tokens/nav/footer/reveal utilities live in site.css)
               ========================================================================== */

    /* ---------- hero ---------- */
    .hero {
        position: relative;
        min-height: 92vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        isolation: isolate;
    }

    .hero__bg {
        position: absolute;
        inset: -12% 0;
        background-size: cover;
        background-position: center;
        z-index: -2;
        will-change: transform;
    }

    .hero__overlay {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: linear-gradient(100deg, rgba(10,38,71,0.94) 0%, rgba(10,38,71,0.72) 38%, rgba(10,38,71,0.22) 62%, rgba(10,38,71,0.05) 100%);
    }

    .hero__content {
        max-width: 640px;
        padding-top: 40px;
        padding-bottom: 40px;
        margin-left: 0 !important;
        margin-right: auto !important;
        padding-left: 60px;
    }

    .hero__kicker {
        font-family: var(--font-display);
        font-weight: 600;
        letter-spacing: 0.32em;
        font-size: 0.78rem;
        color: rgba(255,255,255,0.75);
        text-transform: uppercase;
        margin-bottom: 22px;
    }

    .hero__title {
        font-size: clamp(2.1rem, 5vw, 3.4rem);
        line-height: 1.12;
        color: #fff;
        font-weight: 800;
        margin-bottom: 20px;
    }

        .hero__title span {
            color: var(--red-600);
        }

    .hero__desc {
        color: rgba(255,255,255,0.82);
        font-size: 1.02rem;
        line-height: 1.65;
        max-width: 460px;
        margin-bottom: 32px;
    }

    .hero__dots {
        position: absolute;
        left: 50%;
        bottom: 26px;
        transform: translateX(-50%);
        display: flex;
        gap: 8px;
        z-index: 2;
    }

        .hero__dots span {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255,255,255,0.4);
        }

            .hero__dots span.is-active {
                background: var(--red-600);
                width: 22px;
                border-radius: 5px;
                transition: all 0.3s var(--ease);
            }

    /* ---------- trading focus ---------- */
    .focus {
        padding: 96px 0 88px;
        background: var(--bg-white);
    }

    .focus__grid {
        margin-top: 48px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 22px;
    }

    .focus__card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 30px 22px;
        text-align: center;
        transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
    }

        .focus__card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-card);
            border-color: transparent;
        }

    .focus__icon {
        width: 58px;
        height: 58px;
        margin: 0 auto 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-soft);
        color: var(--navy-800);
        transition: background 0.3s var(--ease), color 0.3s var(--ease);
    }

    .focus__card:hover .focus__icon {
        background: var(--red-600);
        color: #fff;
    }

    .focus__card h3 {
        font-size: 1.02rem;
        letter-spacing: 0.03em;
        margin-bottom: 10px;
    }

    .focus__card p {
        font-size: 0.88rem;
        color: var(--ink-500);
        line-height: 1.55;
        margin: 0;
    }

    /* ---------- about ---------- */
    .about {
        padding: 20px 0 100px;
        background: var(--bg-white);
    }

    .about__grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .about__media {
        position: relative;
    }

        .about__media::before {
            content: '';
            position: absolute;
            top: -18px;
            left: -18px;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--navy-900), var(--red-600));
            border-radius: var(--radius);
            z-index: -1;
            clip-path: polygon(0 0, 100% 0, 100% 82%, 82% 100%, 0 100%);
        }

        .about__media img {
            border-radius: var(--radius);
            width: 100%;
            aspect-ratio: 4/3;
            object-fit: cover;
        }

    .about__eyebrow {
        font-family: var(--font-display);
        font-weight: 700;
        letter-spacing: 0.14em;
        font-size: 0.8rem;
        text-transform: uppercase;
        color: var(--ink-500);
        margin-bottom: 12px;
    }

    .about__body h2 {
        font-size: clamp(1.5rem, 2.6vw, 2.1rem);
        margin-bottom: 18px;
    }

        .about__body h2 span {
            color: var(--red-600);
        }

    .about__body p {
        color: var(--ink-500);
        line-height: 1.75;
        margin-bottom: 26px;
    }

    /* ---------- stats ---------- */
    .stats {
        background: linear-gradient(120deg, var(--navy-900), var(--navy-700));
        padding: 46px 0;
    }

    .stats__grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        text-align: center;
    }

        .stats__grid > div {
            border-right: 1px solid rgba(255,255,255,0.14);
        }

            .stats__grid > div:last-child {
                border-right: none;
            }

    .stats__num {
        font-family: var(--font-display);
        font-weight: 800;
        font-size: clamp(1.7rem, 3.4vw, 2.4rem);
        color: #fff;
    }

        .stats__num .plus {
            color: var(--red-600);
        }

    .stats__label {
        margin-top: 6px;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.65);
    }

    /* ---------- clients ---------- */
    .clients {
        padding: 96px 0;
        background: var(--bg-soft);
    }

    .clients__grid {
        margin-top: 48px;
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 16px;
    }

    .clients__badge {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 18px 20px;
        height: 110px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
    }

        .clients__badge:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-card);
        }

        .clients__badge img {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
            object-fit: contain;
        }

    /* ---------- CTA banner ---------- */
    .cta {
        position: relative;
        overflow: hidden;
        isolation: isolate;
        min-height: 340px;
        display: flex;
        align-items: center;
    }

    .cta__bg {
        position: absolute;
        inset: -14% 0;
        background-size: cover;
        background-position: center;
        z-index: -2;
        will-change: transform;
    }

    .cta__overlay {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: linear-gradient(100deg, rgba(10,38,71,0.92) 0%, rgba(10,38,71,0.55) 55%, rgba(10,38,71,0.15) 100%);
    }

    .cta__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 30px;
        flex-wrap: wrap;
    }

    .cta__text h2 {
        color: #fff;
        font-size: clamp(1.4rem, 2.6vw, 1.9rem);
        margin-bottom: 8px;
    }

    .cta__text p {
        color: rgba(255,255,255,0.8);
        max-width: 480px;
        margin: 0;
        line-height: 1.6;
    }

    @@media (max-width: 1000px) {
        .focus__grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .about__grid {
            grid-template-columns: 1fr;
        }

        .clients__grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .stats__grid {
            grid-template-columns: repeat(2, 1fr);
            row-gap: 24px;
        }

            .stats__grid > div:nth-child(2) {
                border-right: none;
            }
    }

    @@media (max-width: 560px) {
        .focus__grid {
            grid-template-columns: 1fr;
        }

        .clients__grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .hero {
            min-height: 100vh;
        }
    }
</style>

<!-- ================= HERO ================= -->
<section class="hero" id="hero">
    <div class="hero__bg parallax-layer" data-parallax="0.28" style="background-image:url('@Url.Content("~/images/hero-port.png")')"></div>
    <div class="hero__overlay"></div>
    <div class="container hero__content">
        <p class="hero__kicker reveal reveal-up">Connecting Markets · Creating a Better Tomorrow</p>
        <h1 class="hero__title reveal reveal-up" style="transition-delay:.1s">Global Trading.<br /><span>Greater Possibilities.</span></h1>
        <p class="hero__desc reveal reveal-up" style="transition-delay:.2s">SM Explorer is a dynamic trading company committed to delivering quality products, reliable service and lasting value across global markets.</p>
        <a href="/Home/Career" class="btn btn--primary">
            VIEW COMPANY PROFILE
        </a>
    </div>
    <div class="hero__dots" aria-hidden="true">
        <span class="is-active"></span><span></span><span></span>
    </div>
</section>

