                    new { Name = "Mubadala Energy", Logo = "mubadala-energy.jpg" },
                    new { Name = "Petrofac", Logo = "petrofac.jpg" },
                    new { Name = "Petronas Carigali", Logo = "petronas-carigali.jpg" },
                    new { Name = "POSCO Malaysia", Logo = "posco-malaysia.jpg" },
                    new { Name = "TotalEnergies", Logo = "totalenergies.png" },
