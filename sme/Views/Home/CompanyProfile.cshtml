@{
    ViewData["Title"] = "About Us";
}

<style>
    /* ---------- HERO ---------- */
    .sm-hero {
        position: relative;
        min-height: 420px;
        display: flex;
        align-items: center;
        padding: 0 60px;
        overflow: hidden;
    }

    .sm-hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 45%;
        z-index: 0;
    }

    .sm-hero-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(100deg, rgba(11,31,58,0.85) 0%, rgba(11,31,58,0.55) 42%, rgba(11,31,58,0.15) 100%);
        pointer-events: none;
    }

    .sm-hero::after {
        content: "";
        position: absolute;
        right: -6%;
        top: 0;
        bottom: 0;
        width: 45%;
        background: linear-gradient(120deg, transparent 46%, rgba(227,30,36,0.5) 47.5%, transparent 49%);
        pointer-events: none;
        z-index: 1;
    }

    .sm-hero-content {
        position: relative;
        z-index: 2;
        max-width: 600px;
    }

        .sm-hero-content h1 {
            color: #fff;
            font-size: 2.6rem;
            font-weight: 800;
            margin: 0 0 14px 0;
            letter-spacing: .5px;
            opacity: 0;
            transform: translateY(24px);
        }

        .sm-hero-content p {
            color: #d7deea;
            font-size: 1.05rem;
            margin: 0;
            max-width: 460px;
            opacity: 0;
            transform: translateY(24px);
        }

    .sm-hero.sm-loaded .sm-hero-content h1 {
        animation: smFadeUp .8s ease forwards .15s;
    }

    .sm-hero.sm-loaded .sm-hero-content p {
        animation: smFadeUp .8s ease forwards .4s;
    }

    @@keyframes smFadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }


    /* ---------- REVEAL ---------- */
    .sm-reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity .8s ease, transform .8s ease;
    }

        .sm-reveal.sm-visible {
            opacity: 1;
            transform: translateY(0);
        }

    .sm-reveal-delay-1.sm-visible {
        transition-delay: .1s;
    }

    .sm-reveal-delay-2.sm-visible {
        transition-delay: .2s;
    }

    .sm-reveal-delay-3.sm-visible {
        transition-delay: .3s;
    }

    .sm-reveal-delay-4.sm-visible {
        transition-delay: .4s;
    }
</style>

<!-- HERO -->
<section class="sm-hero" id="smHero">
    <img class="sm-hero-bg" src="~/images/cp-hero-bg.png" alt="" />
    <div class="sm-hero-overlay"></div>
    <div class="sm-hero-content">
        <h1>COMPANY <span style="color:red">PROFILE</span></h1>
        <p>SM Explorer Sdn Bhd is a Malaysia-registered trading company specialising 
            in offshore and onshore equipment and maintenance solutions for the oil, gas, and engineering sectors.</p>
    </div>
</section>

<!-- ================= WHO WE ARE (Hero split section) ================= -->
<section class="sm-about-hero sm-reveal">
    <div class="sm-about-hero-inner">

        <!-- Left: photo + heading + copy -->
        <div class="sm-about-hero-left">
            <div class="sm-about-hero-photo">
                <img src="~/images/companyprofile-hero-bg.png" alt="SM Explorer offshore &amp; onshore trading" />
            </div>

            <div class="sm-about-hero-copy">
                <span class="sm-eyebrow">About Us</span>
                <h1>Who We Are</h1>
                <p>
                    SM Explorer Sdn Bhd is a registered company under the Companies Commission of
                    Malaysia (SSM) and the Ministry of Finance, specialised in trading for offshore
                    and onshore equipment and maintenance.
                </p>
                <p>
                    We are fully committed to delivering superior quality products and services that
                    meet international standards, while remaining accessible and cost-effective for
                    all our clients across Malaysia's oil, gas, and engineering sectors.
                </p>

                <ul class="sm-about-hero-points">
                    <li>Registered under SSM &amp; Ministry of Finance</li>
                    <li>Specialised in offshore &amp; onshore trading</li>
                    <li>Meeting international standards</li>
                </ul>

                <a href="/Home/Contact" class="sm-about-hero-btn">GET IN TOUCH</a>
            </div>
        </div>

        <!-- Right: Vision / Mission / Values summary cards -->
        <div class="sm-about-hero-right">
            <div class="sm-vmv-card sm-reveal sm-reveal-delay-1">
                <div class="sm-vmv-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" />
                        <circle cx="12" cy="12" r="3" />
                    </svg>
                </div>
                <div class="sm-vmv-text">
                    <h3>Our Vision</h3>
                    <p>To be a trusted global trading partner creating sustainable value and growth.</p>
                </div>
            </div>

            <div class="sm-vmv-card sm-reveal sm-reveal-delay-2">
                <div class="sm-vmv-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2 3 6v6c0 5 4 9 9 10 5-1 9-5 9-10V6l-9-4Z" />
                    </svg>
                </div>
                <div class="sm-vmv-text">
                    <h3>Our Mission</h3>
                    <p>To deliver quality products and exceptional service through trust, teamwork and innovation.</p>
                </div>
            </div>

            <div class="sm-vmv-card sm-reveal sm-reveal-delay-3">
                <div class="sm-vmv-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m12 3 2.6 5.4 6 .8-4.3 4.2 1 6-5.3-2.8L6.7 19.4l1-6-4.3-4.2 6-.8L12 3Z" />
                    </svg>
                </div>
                <div class="sm-vmv-text">
                    <h3>Our Values</h3>
                    <p>Integrity, Excellence, Reliability, Teamwork and Customer Focus.</p>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- ================= OUR MISSION (full section) ================= -->
<section class="sm-mission sm-reveal">
    <div class="sm-mission-inner">
        <span class="sm-eyebrow">Our Mission</span>
        <h2>What We Strive For</h2>
        <p>
            The company aims to establish a new model for how service providers deliver superior
            quality service and equipment that meet international standards at a reasonable cost.
        </p>
        <p>
            We wish to expand all our clients' capacity to utilise the latest technology, combining
            a reliable online portal to source products, services and equipment available for their
            requirements — all at a reasonable and transparent cost.
        </p>

        <ul class="sm-mission-points">
            <li>New standard in service delivery</li>
            <li>Reliable online portal for sourcing</li>
            <li>Reasonable cost for all clients</li>
        </ul>
    </div>
</section>

<!-- ================= OUR CORE VALUES ================= -->
<section class="sm-values sm-reveal">
    <div class="sm-values-inner">
        <span class="sm-eyebrow">What Drives Us</span>
        <h2>Our Core Values</h2>

        <div class="sm-values-grid">
            <div class="sm-value-card sm-reveal sm-reveal-delay-1">
                <div class="sm-value-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2 3 6v6c0 5 4 9 9 10 5-1 9-5 9-10V6l-9-4Z" />
                    </svg>
                </div>
                <h3>Reliable</h3>
                <p>Meet international standards to operate in harsh environments, onshore and offshore.</p>
            </div>

            <div class="sm-value-card sm-reveal sm-reveal-delay-2">
                <div class="sm-value-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M13 2 3 14h7l-1 8 11-14h-7l0-6Z" />
                    </svg>
                </div>
                <h3>Fast</h3>
                <p>Our team provides fast and immediate response 24/7 to support our clients whenever needed.</p>
            </div>

            <div class="sm-value-card sm-reveal sm-reveal-delay-3">
                <div class="sm-value-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m9 12 2 2 4-4" />
                        <circle cx="12" cy="12" r="9" />
                    </svg>
                </div>
                <h3>Commitment</h3>
                <p>"Our commitment is our promise." We honour every obligation to our clients, partners and stakeholders.</p>
            </div>

            <div class="sm-value-card sm-reveal sm-reveal-delay-1">
                <div class="sm-value-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-11V5l-8-3-8 3v6c0 7 8 11 8 11Z" />
                    </svg>
                </div>
                <h3>Safe</h3>
                <p>All our products and services meet the required HSE standards across every industry we serve.</p>
            </div>

            <div class="sm-value-card sm-reveal sm-reveal-delay-2">
                <div class="sm-value-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="9" />
                        <path d="M12 7v5l3 3" />
                    </svg>
                </div>
                <h3>Reasonable</h3>
                <p>All our products and services are offered at a reasonable and transparent cost without compromise.</p>
            </div>
        </div>
    </div>
</section>

<style>
    :root {
        --sm-navy: #0b1f3a;
        --sm-navy-dark: #071527;
        --sm-red: #c81e2c;
        --sm-red-dark: #a5161f;
        --sm-ink: #1c2833;
        --sm-muted: #5a6b7d;
        --sm-line: #e6eaf0;
        --sm-bg-soft: #f6f8fb;
    }

    .sm-eyebrow {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--sm-red);
        margin-bottom: 0.75rem;
    }

    /* ---- Who We Are hero ---- */
    .sm-about-hero {
        padding: 5rem 1.5rem;
        background: #fff;
    }

    .sm-about-hero-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 3rem;
        align-items: stretch;
    }

    .sm-about-hero-left {
        position: relative;
        border-radius: 14px;
        overflow: hidden;
        background: var(--sm-navy);
        min-height: 460px;
        display: flex;
        align-items: flex-end;
    }

    .sm-about-hero-photo {
        position: absolute;
        inset: 0;
    }

        .sm-about-hero-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.55;
        }

        .sm-about-hero-photo::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(11,31,58,0.15) 0%, rgba(11,31,58,0.92) 85%);
        }

    .sm-about-hero-copy {
        position: relative;
        z-index: 1;
        padding: 2.5rem;
        color: #fff;
    }

        .sm-about-hero-copy h1 {
            font-size: 2.1rem;
            font-weight: 800;
            margin: 0 0 1rem;
            color: #fff;
        }

        .sm-about-hero-copy p {
            color: #d6dee8;
            line-height: 1.7;
            margin: 0 0 1rem;
            max-width: 46ch;
        }

    .sm-about-hero-points {
        list-style: none;
        margin: 1.25rem 0 1.75rem;
        padding: 0;
    }

        .sm-about-hero-points li {
            position: relative;
            padding-left: 1.4rem;
            margin-bottom: 0.5rem;
            color: #eef2f7;
            font-weight: 500;
        }

            .sm-about-hero-points li::before {
                content: "";
                position: absolute;
                left: 0;
                top: 0.55rem;
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--sm-red);
            }

    .sm-about-hero-btn {
        display: inline-block;
        background: var(--sm-red);
        color: #fff;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.06em;
        padding: 0.85rem 1.75rem;
        border-radius: 6px;
        text-decoration: none;
        transition: background 0.2s ease;
    }

        .sm-about-hero-btn:hover {
            background: var(--sm-red-dark);
        }

    /* ---- Vision / Mission / Values summary cards ---- */
    .sm-about-hero-right {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        justify-content: center;
    }

    .sm-vmv-card {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        background: var(--sm-bg-soft);
        border: 1px solid var(--sm-line);
        border-radius: 12px;
        padding: 1.5rem;
    }

    .sm-vmv-icon {
        flex: none;
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background: var(--sm-navy);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sm-vmv-text h3 {
        margin: 0 0 0.35rem;
        font-size: 1rem;
        font-weight: 700;
        color: var(--sm-navy);
    }

    .sm-vmv-text p {
        margin: 0;
        font-size: 0.9rem;
        line-height: 1.55;
        color: var(--sm-muted);
    }

    /* ---- Our Mission section ---- */
    .sm-mission {
        padding: 5rem 1.5rem;
        background: var(--sm-bg-soft);
    }

    .sm-mission-inner {
        max-width: 780px;
        margin: 0 auto;
        text-align: center;
    }

        .sm-mission-inner h2 {
            font-size: 1.9rem;
            font-weight: 800;
            color: var(--sm-navy);
            margin: 0 0 1.25rem;
        }

        .sm-mission-inner p {
            color: var(--sm-muted);
            line-height: 1.75;
            margin: 0 0 1rem;
        }

    .sm-mission-points {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem 1.5rem;
        margin: 1.75rem 0 0;
        padding: 0;
    }

        .sm-mission-points li {
            position: relative;
            padding-left: 1.4rem;
            font-weight: 600;
            color: var(--sm-navy);
        }

            .sm-mission-points li::before {
                content: "";
                position: absolute;
                left: 0;
                top: 0.5rem;
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--sm-red);
            }

    /* ---- Core Values section ---- */
    .sm-values {
        padding: 5rem 1.5rem;
        background: #fff;
    }

    .sm-values-inner {
        max-width: 1200px;
        margin: 0 auto;
        text-align: center;
    }

        .sm-values-inner h2 {
            font-size: 1.9rem;
            font-weight: 800;
            color: var(--sm-navy);
            margin: 0 0 2.5rem;
        }

    .sm-values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 1.5rem;
        text-align: left;
    }

    .sm-value-card {
        border: 1px solid var(--sm-line);
        border-radius: 12px;
        padding: 1.75rem 1.5rem;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

        .sm-value-card:hover {
            box-shadow: 0 12px 28px rgba(11,31,58,0.10);
            transform: translateY(-3px);
        }

    .sm-value-icon {
        width: 46px;
        height: 46px;
        border-radius: 10px;
        background: var(--sm-navy);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .sm-value-card h3 {
        margin: 0 0 0.5rem;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--sm-navy);
    }

    .sm-value-card p {
        margin: 0;
        font-size: 0.9rem;
        line-height: 1.6;
        color: var(--sm-muted);
    }

    /* ---- Scroll reveal (shared pattern) ---- */
    .sm-reveal {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

        .sm-reveal.sm-visible {
            opacity: 1;
            transform: translateY(0);
        }

    .sm-reveal-delay-1.sm-visible {
        transition-delay: 0.05s;
    }

    .sm-reveal-delay-2.sm-visible {
        transition-delay: 0.15s;
    }

    .sm-reveal-delay-3.sm-visible {
        transition-delay: 0.25s;
    }

    @@media (max-width: 900px) {
        .sm-about-hero-inner {
            grid-template-columns: 1fr;
        }

        .sm-about-hero-left {
            min-height: 380px;
        }
    }
</style>

<script>
    (function() {
        // Hero entrance animation — fade/slide in the title & paragraph
        var hero = document.getElementById('smHero');
        if (hero) {
            window.requestAnimationFrame(function() {
                setTimeout(function() { hero.classList.add('sm-loaded'); }, 50);
            });
        }

        // Scroll reveal
        var revealEls = document.querySelectorAll('.sm-reveal');
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('sm-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
        revealEls.forEach(function(el) { observer.observe(el); });
    })();
</script>
