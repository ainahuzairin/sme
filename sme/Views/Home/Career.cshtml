@{
    ViewData["Title"] = "Careers";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --sm-red: #E31E24;
        --sm-navy: #0B1F3A;
        --sm-navy-light: #132a4d;
        --sm-gray: #6b7280;
        --sm-border: #e5e7eb;
    }

    .sm-career-page {
        font-family: 'Poppins', sans-serif;
        color: #1f2937;
        overflow-x: hidden;
    }

        .sm-career-page * {
            box-sizing: border-box;
        }

    /* ---------- HERO ---------- */
    .sm-hero {
        position: relative;
        min-height: 420px;
        display: flex;
        align-items: center;
        padding: 0 60px;
        overflow: hidden;
    }

    .sm-hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 45%;
        z-index: 0;
    }

    .sm-hero-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(100deg, rgba(11,31,58,0.85) 0%, rgba(11,31,58,0.55) 42%, rgba(11,31,58,0.15) 100%);
        pointer-events: none;
    }

    .sm-hero::after {
        content: "";
        position: absolute;
        right: -6%;
        top: 0;
        bottom: 0;
        width: 45%;
        background: linear-gradient(120deg, transparent 46%, rgba(227,30,36,0.5) 47.5%, transparent 49%);
        pointer-events: none;
        z-index: 1;
    }

    .sm-hero-content {
        position: relative;
        z-index: 2;
        max-width: 600px;
    }

        .sm-hero-content h1 {
            color: #fff;
            font-size: 2.6rem;
            font-weight: 800;
            margin: 0 0 14px 0;
            letter-spacing: .5px;
            opacity: 0;
            transform: translateY(24px);
        }

        .sm-hero-content p {
            color: #d7deea;
            font-size: 1.05rem;
            margin: 0;
            max-width: 460px;
            opacity: 0;
            transform: translateY(24px);
        }

    .sm-hero.sm-loaded .sm-hero-content h1 {
        animation: smFadeUp .8s ease forwards .15s;
    }

    .sm-hero.sm-loaded .sm-hero-content p {
        animation: smFadeUp .8s ease forwards .4s;
    }

    @@keyframes smFadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ---------- REVEAL ---------- */
    .sm-reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity .8s ease, transform .8s ease;
    }

        .sm-reveal.sm-visible {
            opacity: 1;
            transform: translateY(0);
        }

    .sm-reveal-delay-1.sm-visible {
        transition-delay: .1s;
    }

    .sm-reveal-delay-2.sm-visible {
        transition-delay: .2s;
    }

    .sm-reveal-delay-3.sm-visible {
        transition-delay: .3s;
    }

    .sm-reveal-delay-4.sm-visible {
        transition-delay: .4s;
    }

    /* ---------- WHY JOIN ---------- */
    .sm-why {
        padding: 70px 60px 40px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .sm-why-label {
        color: var(--sm-red);
        font-weight: 700;
        letter-spacing: 2px;
        font-size: .8rem;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .sm-why h2 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--sm-navy);
        margin: 0 0 40px 0;
    }

    .sm-why-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 22px;
    }

    @@media (max-width: 900px) {
        .sm-why-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 560px) {
        .sm-why-grid {
            grid-template-columns: 1fr;
        }
    }

    .sm-why-card {
        background: #fff;
        border: 1px solid var(--sm-border);
        border-radius: 10px;
        padding: 26px 22px;
        transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease;
    }

        .sm-why-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 28px rgba(11,31,58,0.08);
            border-color: transparent;
        }

    .sm-why-icon {
        width: 46px;
        height: 46px;
        border-radius: 8px;
        background: rgba(227,30,36,0.1);
        color: var(--sm-red);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    .sm-why-card h4 {
        margin: 0 0 6px 0;
        font-size: .95rem;
        font-weight: 700;
        color: var(--sm-navy);
    }

    .sm-why-card p {
        margin: 0;
        font-size: .85rem;
        color: var(--sm-gray);
        line-height: 1.5;
    }

    /* ---------- CURRENT OPENINGS ---------- */
    .sm-openings {
        padding: 40px 60px 30px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .sm-openings-label {
        color: var(--sm-red);
        font-weight: 700;
        letter-spacing: 2px;
        font-size: .8rem;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .sm-openings h2 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--sm-navy);
        margin: 0 0 32px 0;
    }

    .sm-job-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .sm-job-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        background: #fff;
        border: 1px solid var(--sm-border);
        border-left: 4px solid var(--sm-red);
        border-radius: 10px;
        padding: 20px 24px;
        transition: transform .3s ease, box-shadow .3s ease;
    }

        .sm-job-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 28px rgba(11,31,58,0.08);
        }

    .sm-job-info h4 {
        margin: 0 0 6px 0;
        font-size: 1rem;
        font-weight: 700;
        color: var(--sm-navy);
    }

    .sm-job-info p {
        margin: 0;
        font-size: .85rem;
        color: var(--sm-gray);
    }

    .sm-apply-btn {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--sm-red);
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 11px 22px;
        font-weight: 600;
        font-size: .85rem;
        text-decoration: none;
        cursor: pointer;
        transition: transform .25s ease, box-shadow .25s ease, background .25s ease;
        white-space: nowrap;
    }

        .sm-apply-btn:hover {
            background: #c81820;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(227,30,36,0.3);
        }

        .sm-apply-btn svg {
            transition: transform .25s ease;
        }

        .sm-apply-btn:hover svg {
            transform: translateX(4px);
        }

    @@media (max-width: 620px) {
        .sm-job-card {
            flex-direction: column;
            align-items: flex-start;
        }

        .sm-apply-btn {
            width: 100%;
            justify-content: center;
        }
    }

    /* ---------- CTA BANNER ---------- */
    .sm-cta-section {
        padding: 40px 60px 70px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .sm-cta-banner {
        position: relative;
        border-radius: 14px;
        overflow: hidden;
        min-height: 220px;
        display: flex;
        align-items: center;
        padding: 40px 50px;
        box-shadow: 0 20px 40px rgba(11,31,58,0.12);
    }

    .sm-cta-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    .sm-cta-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(100deg, rgba(11,31,58,0.92) 0%, rgba(11,31,58,0.65) 55%, rgba(11,31,58,0.35) 100%);
    }

    .sm-cta-content {
        position: relative;
        z-index: 2;
        max-width: 520px;
    }

        .sm-cta-content h3 {
            color: #fff;
            font-size: 1.6rem;
            font-weight: 800;
            margin: 0 0 10px 0;
        }

        .sm-cta-content p {
            color: #d7deea;
            font-size: .95rem;
            margin: 0 0 22px 0;
            line-height: 1.5;
        }

    .sm-resume-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--sm-red);
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 13px 28px;
        font-weight: 600;
        font-size: .95rem;
        text-decoration: none;
        cursor: pointer;
        transition: transform .25s ease, box-shadow .25s ease, background .25s ease;
    }

        .sm-resume-btn:hover {
            background: #c81820;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(227,30,36,0.3);
        }

        .sm-resume-btn svg {
            transition: transform .25s ease;
        }

        .sm-resume-btn:hover svg {
            transform: translateX(4px);
        }
</style>

